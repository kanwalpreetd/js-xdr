{
  "name": "@stellar/js-xdr",
  "version": "5.0.0-rc.1",
  "description": "Read/write XDR encoded data structures (RFC 4506)",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "main": "./dist/js-xdr.cjs",
  "module": "./dist/js-xdr.mjs",
  "types": "./dist/js-xdr.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/js-xdr.d.ts",
        "default": "./dist/js-xdr.mjs"
      },
      "require": {
        "types": "./dist/js-xdr.d.ts",
        "default": "./dist/js-xdr.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "pnpm run clean && rollup -c rollup.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test-generate": "bundle exec xdrgen -o generated -n test -l javascript examples/test.x",
    "fixtures:generate-v4": "node test/fixtures/generate-v4-compat.cjs",
    "fmt": "prettier --write '**/*.{js,ts,json}'",
    "prepare": "husky",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stellar/js-xdr.git"
  },
  "keywords": [],
  "author": "Stellar Development Foundation <hello@stellar.org>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/stellar/js-xdr/issues"
  },
  "homepage": "https://github.com/stellar/js-xdr",
  "lint-staged": {
    "**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{js,mjs,json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "husky": "^9.1.7",
    "js-xdr-v4": "npm:@stellar/js-xdr@4.0.0",
    "lint-staged": "13.2.2",
    "prettier": "^2.8.7",
    "rollup": "^4.53.3",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-esbuild": "^6.2.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.0"
  }
}
